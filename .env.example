PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
TERRAFORM_API_BASE_URL=https://app.terraform.io/api/v2
TERRAFORM_API_TOKEN=replace-with-a-read-only-token
TERRAFORM_ORGANIZATION=your-organization
# Optional comma-separated allowlist. Defaults to TERRAFORM_ORGANIZATION.
TERRAFORM_ALLOWED_ORGANIZATIONS=your-organization
# Enable OAuth validation for ChatGPT/OpenCode. Requires Auth0 issuer + audience.
AUTH_OAUTH_ENABLED=true
OAUTH_ISSUER_URL=https://your-tenant.us.auth0.com/
OAUTH_AUDIENCE=https://terraform-cloud-mcp
# Optional scopes/subjects allowlists. Defaults to terraform:read.
OAUTH_REQUIRED_SCOPES=terraform:read
OAUTH_ALLOWED_SUBJECTS=
# Optional API key auth for scripts or non-interactive clients.
AUTH_API_KEY_ENABLED=false
MCP_API_KEY_SECRET=
# Optional legacy bearer token for clients that still use a static Authorization header.
MCP_BEARER_TOKEN=
REQUEST_TIMEOUT_MS=15000
