{
  "name": "terraform-cloud-mcp",
  "version": "0.1.0",
  "description": "Read-only MCP server for managing and diagnosing HCP Terraform workspaces, runs, and plans from ChatGPT.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --env-file=.env --watch --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "check": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "mcp",
    "terraform-cloud",
    "hcp-terraform",
    "chatgpt",
    "infrastructure"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "5.2.1",
    "jose": "^6.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "tsx": "^4.20.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
